{
  "manifest_version": 3,
  "name": "Once Every 3 Hours",
  "version": "1.0.0",
  "description": "Locks distracting sites except for one visit every 3 hours. Focus. Put the effort in. That's the only way.",
  "permissions": ["tabs", "webNavigation", "storage"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Once Every 3 Hours",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["blocked.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
